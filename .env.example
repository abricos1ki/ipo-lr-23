# Пример переменных окружения для настройки отправки почты (лр19).
# Скопируйте этот файл в .env (или экспортируйте переменные другим способом)
# и заполните реальными значениями. Без этих переменных письма с чеками
# будут выводиться в консоль сервера разработки вместо реальной отправки.

# Логин от почтового ящика на Яндексе (полный email)
EMAIL_HOST_USER=your_login@yandex.ru

# Пароль приложения, созданный в настройках Яндекс ID
# (не обычный пароль от почты! https://id.yandex.ru/security/app-passwords)
EMAIL_HOST_PASSWORD=your_app_password
