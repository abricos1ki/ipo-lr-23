# ─────────────────────────────────────────────────────────────────────
# Шаблон файла переменных окружения для локальной разработки.
# Скопируйте в .env, заполните значения и НЕ коммитьте .env в git!
# На Railway эти переменные задаются в разделе Variables → вкладка проекта.
# ─────────────────────────────────────────────────────────────────────

# ─── Обязательные ────────────────────────────────────────────────────

# Секретный ключ Django (сгенерируйте: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=замените-на-реальный-ключ

# Режим отладки: True (локально) или False (продакшн/Railway)
DJANGO_DEBUG=True

# Разрешённые хосты через запятую (для Railway добавляется автоматически через RAILWAY_PUBLIC_DOMAIN)
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── База данных ──────────────────────────────────────────────────────
# На Railway: Railway сам устанавливает DATABASE_URL при добавлении PostgreSQL.
# Локально: оставьте пустым — будет использован SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Email (Yandex SMTP) ──────────────────────────────────────────────
# Необязательно. Без этих переменных письма выводятся в консоль.
# EMAIL_HOST_USER=your_login@yandex.ru
# EMAIL_HOST_PASSWORD=пароль_приложения_из_яндекс_id

# ─── Только для Railway (платформа устанавливает автоматически) ───────
# RAILWAY_PUBLIC_DOMAIN=your-project.up.railway.app
# PORT=8000

# ─── Необязательные (при необходимости) ──────────────────────────────
# Дополнительные trusted origins для CSRF (через запятую):
# CSRF_TRUSTED_ORIGINS=https://your-domain.up.railway.app
